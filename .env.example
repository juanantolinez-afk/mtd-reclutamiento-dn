# Bizneo ATS
BIZNEO_API_TOKEN=TU_TOKEN_AQUI
BIZNEO_API_EMAIL=TU_EMAIL_API_BIZNEO
BIZNEO_COMPANY_ID=TU_COMPANY_ID
BIZNEO_API_URL=https://ats.bizneo.com/api/v3

# OpenRouter — modelo LLM para parseo de CVs
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# Google Sheets — service account para guardar candidatos
GOOGLE_CLIENT_EMAIL=tu-service-account@proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=ID_DEL_SPREADSHEET

# Google OAuth (login con Gmail corporativo)
# 1. console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID → Web Application
# 2. Authorized JS origins: http://localhost:3000 y tu dominio de producción
# 3. Solo necesitas el Client ID (NO el secret para este flujo)
GOOGLE_OAUTH_CLIENT_ID=

# Auth JWT — cambia este valor antes de deploy a producción
JWT_SECRET=cambia-este-valor-en-produccion-min-32-chars

# Servidor
PORT=3000
NODE_ENV=development
